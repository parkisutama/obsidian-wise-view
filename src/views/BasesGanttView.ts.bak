/**
 * BasesGanttView — Frappe Gantt integration for Obsidian Bases.
 *
 * Architecture:
 *  - Reads frontmatter properties for start/end date, progress, dependencies, and colorBy.
 *  - Renders using Frappe Gantt (https://github.com/frappe/gantt).
 *  - Colors resolved via 3-tier priority: Pretty Properties → valueStyles → stringToColor.
 *  - On bar click: opens file or shows hover preview.
 *  - On date drag: writes updated dates back to frontmatter (single source of truth).
 *  - View configuration exposed through Bases' native config sidebar options.
 */

import {
    BasesView,
    BasesViewRegistration,
    BasesEntry,
    BasesPropertyId,
    BasesAllOptions,
    QueryController,
    DateValue,
    NumberValue,
    NullValue,
    Value,
    Menu,
} from 'obsidian';
import Gantt from 'frappe-gantt';
import type { FrappeTask, GanttOptions, PopupContext } from 'frappe-gantt';
import type PlannerPlugin from '../main';
import { stringToColor } from '../utils/colorUtils';
import { openFileInNewTab } from '../utils/openFile';

// ── View ID ─────────────────────────────────────────────────────────────────

export const BASES_GANTT_VIEW_ID = 'wise-view-gantt';

// ── Internal types ───────────────────────────────────────────────────────────

/** Extended task type carrying the original file path for click-to-open. */
interface GanttTask extends FrappeTask {
    filePath: string;
    isMilestone?: boolean;
}

/** Configuration derived from view options for mapping entries to tasks. */
interface TaskMapperConfig {
    startProperty: BasesPropertyId | null;
    endProperty: BasesPropertyId | null;
    labelProperty: BasesPropertyId | null;
    dependenciesProperty: BasesPropertyId | null;
    colorByProperty: BasesPropertyId | null;
    progressProperty: BasesPropertyId | null;
    showProgress: boolean;
}

/** Pretty Properties public API subset we use for color resolution. */
interface PPColorSetting { h: number; s: number; l: number }
interface PrettyPropertiesApi {
    getPropertyBackgroundColorSetting(
        propName: string, propValue: string
    ): string | PPColorSetting | undefined;
}
interface WindowWithPP extends Window { PrettyPropertiesApi?: PrettyPropertiesApi }

/** Phantom group header prefix — tasks with this id prefix are not real items. */
const GROUP_HEADER_PREFIX = '__group__';

/** Number of distinct color slots for gantt bars (driven by CSS). */
const COLOR_SLOT_COUNT = 8;

// ── Passive event-listener patch ─────────────────────────────────────────────
// Frappe Gantt registers touchstart/touchmove/mousewheel/wheel listeners
// without { passive: true }, causing DevTools violations. We patch
// EventTarget.prototype.addEventListener for the lifetime of any open Gantt
// view to upgrade those registrations silently.
// Ref-counted so multiple simultaneous views share a single patch.

const PASSIVE_EVENTS = new Set(['touchstart', 'touchmove', 'mousewheel', 'wheel']);
let _passivePatchDepth = 0;
let _origProtoAdd: typeof EventTarget.prototype.addEventListener | null = null;

function installPassivePatch(): void {
    _passivePatchDepth++;
    if (_passivePatchDepth > 1) return; // already patched by another instance
    _origProtoAdd = EventTarget.prototype.addEventListener;
    const orig = _origProtoAdd;
    EventTarget.prototype.addEventListener = function (
        type: string,
        listener: EventListenerOrEventListenerObject,
        opts?: boolean | AddEventListenerOptions,
    ): void {
        if (PASSIVE_EVENTS.has(type)) {
            if (typeof opts === 'object' && opts !== null) {
                opts = { ...opts, passive: true };
            } else {
                opts = { capture: opts === true, passive: true };
            }
        }
        return orig.call(this, type, listener, opts);
    };
}

function uninstallPassivePatch(): void {
    if (_passivePatchDepth <= 0) return;
    _passivePatchDepth--;
    if (_passivePatchDepth === 0 && _origProtoAdd) {
        EventTarget.prototype.addEventListener = _origProtoAdd;
        _origProtoAdd = null;
    }
}

// ── Date utilities ───────────────────────────────────────────────────────────

/**
 * Parse a date value (string, DateValue, or number) into a JS Date.
 * Appends T00:00:00 to date-only strings to prevent UTC timezone shift.
 */
function parseObsidianDate(value: unknown): Date | null {
    if (value == null) return null;

    // Unwrap Obsidian DateValue
    if (value instanceof DateValue) {
        const str = value.dateOnly().toString();
        return parseObsidianDate(str);
    }

    if (typeof value === 'number') {
        const d = new Date(value);
        return isNaN(d.getTime()) ? null : d;
    }

    if (typeof value === 'string') {
        const s = value.trim();
        if (!s) return null;
        // Date-only: append midnight to prevent UTC shift
        const dateOnly = /^\d{4}-\d{2}-\d{2}$/.test(s);
        const d = new Date(dateOnly ? `${s}T00:00:00` : s);
        return isNaN(d.getTime()) ? null : d;
    }

    return null;
}

/** Format a Date as YYYY-MM-DD (for Frappe Gantt). */
function formatDateForGantt(date: Date): string {
    const y = date.getFullYear();
    const m = String(date.getMonth() + 1).padStart(2, '0');
    const d = String(date.getDate()).padStart(2, '0');
    return `${y}-${m}-${d}`;
}

/** Format a Date as YYYY-MM-DD (for writing back to frontmatter). */
function formatDateForFrontmatter(date: Date): string {
    return formatDateForGantt(date);
}

// ── Task utilities ───────────────────────────────────────────────────────────

/**
 * Stable task ID derived from file path.
 * All characters that are invalid in a CSS identifier (slashes, dots, spaces, etc.)
 * are replaced with underscores so Frappe Gantt can safely use the id in
 * querySelector(".highlight-" + task.id) without a SyntaxError.
 */
function makeTaskId(filePath: string): string {
    return filePath.replace(/[^a-zA-Z0-9_-]/g, '_');
}

/**
 * Extract a plain string from an Obsidian Value object.
 * DateValue uses dateOnly() for clean YYYY-MM-DD output.
 */
function extractRawValue(val: Value | null | undefined): string | null {
    if (val == null || val instanceof NullValue) return null;
    if (val instanceof DateValue) return val.dateOnly().toString();
    return val.toString();
}

/**
 * Create a phantom group-header task spanning the full date range of the group.
 */
function createGroupHeaderTask(
    label: string,
    groupIndex: number,
    groupTasks: GanttTask[],
): GanttTask | null {
    if (groupTasks.length === 0) return null;
    const starts = groupTasks.map(t => t.start).sort();
    const ends = groupTasks.map(t => t.end).sort();
    return {
        id: `${GROUP_HEADER_PREFIX}${groupIndex}`,
        name: label,
        start: starts[0],
        end: ends[ends.length - 1],
        progress: 0,
        dependencies: '',
        custom_class: 'gantt-group-header',
        filePath: '',
    };
}

/**
 * Topological sort — tasks with no dependencies first; ties broken by start date.
 * Ensures dependency arrows always point downward in the chart.
 */
function sortByDependencies(tasks: GanttTask[]): GanttTask[] {
    const idSet = new Set(tasks.map(t => t.id));
    const result: GanttTask[] = [];
    const placed = new Set<string>();

    const place = (task: GanttTask, depth = 0): void => {
        if (placed.has(task.id) || depth > tasks.length) return;
        if (task.dependencies) {
            const depIds = Array.isArray(task.dependencies)
                ? task.dependencies.map(s => String(s).trim())
                : String(task.dependencies).split(',').map(s => s.trim());
            for (const dep of depIds) {
                if (dep && idSet.has(dep) && !placed.has(dep)) {
                    const depTask = tasks.find(t => t.id === dep);
                    if (depTask) place(depTask, depth + 1);
                }
            }
        }
        if (!placed.has(task.id)) {
            placed.add(task.id);
            result.push(task);
        }
    };

    for (const t of tasks) place(t);
    return result;
}

/**
 * Map Bases entries to Frappe GanttTask objects.
 * Color class indices are populated externally via the colorSlotMap.
 */
function mapEntriesToTasks(
    entries: BasesEntry[],
    config: TaskMapperConfig,
    colorSlotMap: Map<string, number>,
): GanttTask[] {
    if (!config.startProperty) return [];

    // Build name→id maps for dependency wikilink resolution
    const nameToId = new Map<string, string>();
    for (const entry of entries) {
        const id = makeTaskId(entry.file.path);
        nameToId.set(entry.file.basename, id);
        const pathNoExt = entry.file.path.replace(/\.[^.]+$/, '');
        nameToId.set(pathNoExt, id);
    }

    const tasks: GanttTask[] = [];

    for (const entry of entries) {
        // Start date (required)
        const startVal = entry.getValue(config.startProperty);
        const rawStart = extractRawValue(startVal);
        const startDate = parseObsidianDate(rawStart);
        if (!startDate) continue;

        // End date (optional — default to start + 1 day)
        let endDate: Date | null = null;
        if (config.endProperty) {
            const endVal = entry.getValue(config.endProperty);
            endDate = parseObsidianDate(extractRawValue(endVal));
        }
        if (!endDate) {
            endDate = new Date(startDate);
            endDate.setDate(endDate.getDate() + 1);
        }
        // Ensure end >= start
        if (endDate < startDate) {
            endDate = new Date(startDate);
            endDate.setDate(endDate.getDate() + 1);
        }

        // Label
        let name = entry.file.basename;
        if (config.labelProperty) {
            const labelVal = entry.getValue(config.labelProperty);
            const raw = extractRawValue(labelVal);
            if (raw?.trim()) name = raw;
        }

        // Progress
        let progress = 0;
        if (config.showProgress && config.progressProperty) {
            const progVal = entry.getValue(config.progressProperty);
            const rawProg = extractRawValue(progVal);
            if (rawProg != null) {
                const num = parseFloat(rawProg);
                if (!isNaN(num)) progress = Math.max(0, Math.min(100, num));
            }
        }

        // Dependencies: resolve [[wikilinks]] and plain names
        let dependencies = '';
        if (config.dependenciesProperty) {
            const depVal = entry.getValue(config.dependenciesProperty);
            const rawDep = extractRawValue(depVal);
            if (rawDep != null) {
                const wikiLinkRe = /\[\[([^\]|]+)(?:\|[^\]]+)?\]\]/g;
                const depIds: string[] = [];
                let match: RegExpExecArray | null;
                while ((match = wikiLinkRe.exec(rawDep)) !== null) {
                    const target = match[1].trim();
                    const id = nameToId.get(target) ?? nameToId.get(target.replace(/\.[^.]+$/, ''));
                    if (id) depIds.push(id);
                }
                if (depIds.length === 0) {
                    // Try plain comma-separated names
                    for (const part of rawDep.split(',')) {
                        const t = part.trim();
                        if (t) {
                            const id = nameToId.get(t) ?? nameToId.get(t.replace(/\.[^.]+$/, ''));
                            if (id) depIds.push(id);
                        }
                    }
                }
                dependencies = depIds.join(', ');
            }
        }

        // Color class from pre-built slot map
        let custom_class = '';
        if (config.colorByProperty) {
            const colorVal = entry.getValue(config.colorByProperty);
            const raw = extractRawValue(colorVal);
            if (raw != null) {
                const idx = colorSlotMap.get(String(raw));
                if (idx !== undefined) {
                    // NOTE: custom_class must NOT contain spaces — Frappe throws on classList.add with spaces
                    custom_class = `gantt-color-${idx}`;
                }
            }
        }

        // Milestone: start === end
        const isMilestone = startDate.getTime() === endDate.getTime();
        if (isMilestone) {
            endDate = new Date(startDate);
            endDate.setDate(endDate.getDate() + 1);
            if (!custom_class) custom_class = 'gantt-milestone';
        }

        tasks.push({
            id: makeTaskId(entry.file.path),
            name,
            start: formatDateForGantt(startDate),
            end: formatDateForGantt(endDate),
            progress,
            dependencies,
            custom_class,
            filePath: entry.file.path,
            isMilestone,
        });
    }

    return sortByDependencies(tasks);
}

// ── View class ───────────────────────────────────────────────────────────────

/**
 * Gantt view for Obsidian Bases.
 * Renders items as a Frappe Gantt chart with full property integration.
 */
export class BasesGanttView extends BasesView {
    type = BASES_GANTT_VIEW_ID;

    /** Static registry for command palette integration. */
    static instances: Set<BasesGanttView> = new Set();

    private plugin: PlannerPlugin;
    private containerEl: HTMLElement;
    private ganttEl: HTMLElement;
    /** Dynamic <style> element injected per-view for bar color overrides. */
    private styleEl: HTMLStyleElement | null = null;
    private gantt: InstanceType<typeof Gantt> | null = null;
    private configSnapshot = '';
    private currentTasks: GanttTask[] = [];
    private taskMap: Map<string, GanttTask> = new Map();
    /** Maps file path → BasesEntry for O(1) popup lookup across all groups. */
    private entryMap: Map<string, BasesEntry> = new Map();
    /** Suppress on_click when a drag just finished. */
    private justDragged = false;
    /** Global mouseup handlers registered by Frappe Gantt (for cleanup). */
    private capturedGlobalHandlers: EventListener[] = [];
    /** Mouseover delegate for bar hover → Obsidian Page Preview. */
    private _barHoverHandler: ((evt: Event) => void) | null = null;
    /** MutationObservers that keep the popup inside the visible viewport. */
    private _popupContainerObs: MutationObserver | null = null;
    private _popupStyleObs: MutationObserver | null = null;
    /** Pending rAF id for popup fixed-position clamping (cancelled on each re-schedule). */
    private _popupClampRafId: number | null = null;
    /** Passive `wheel` handler that replaces Frappe's non-passive `mousewheel` infinite-padding listener. */
    private _infinitePaddingHandler: EventListener | null = null;
    /** Last mousedown viewport coordinates — used to place the popup near the cursor. */
    private _lastMouseClientX = 0;
    private _lastMouseClientY = 0;
    /** mousedown handler registered in registerPopupGuard, removed in destroyGantt. */
    private _containerMouseDownHandler: ((e: MouseEvent) => void) | null = null;
    /** Reference to .gantt-container for mousedown listener cleanup. */
    private _ganttContainer: HTMLElement | null = null;

    constructor(controller: QueryController, containerEl: HTMLElement, plugin: PlannerPlugin) {
        super(controller);
        this.plugin = plugin;
        this.containerEl = containerEl;
    }

    // ── Lifecycle ──────────────────────────────────────────────────────────────

    onload(): void {
        BasesGanttView.instances.add(this);
        installPassivePatch();
        this.containerEl.addClass('bases-gantt-view');
        this.ganttEl = this.containerEl.createDiv({ cls: 'gantt-wrapper' });
        this.styleEl = this.containerEl.createEl('style');
        this.registerContextMenu();
    }

    onunload(): void {
        BasesGanttView.instances.delete(this);
        this.destroyGantt();
        uninstallPassivePatch();
        this.styleEl?.remove();
        this.styleEl = null;
    }

    onResize(): void {
        // Frappe Gantt fills width via SVG 100% — no explicit resize needed.
    }

    // ── Public API (command palette) ───────────────────────────────────────────

    scrollToToday(): void {
        this.gantt?.scroll_current();
    }

    setViewMode(mode: string): void {
        this.gantt?.change_view_mode(mode);
    }

    isInActiveLeaf(): boolean {
        return this.containerEl.isConnected;
    }

    // ── Config getters ─────────────────────────────────────────────────────────

    private getDateStartField(): BasesPropertyId | null {
        const v = this.config.get('dateStartField') as string | undefined;
        if (v) return v as BasesPropertyId;
        const def = this.plugin.settings.ganttDefaults.dateStartField;
        return def ? (def as BasesPropertyId) : null;
    }

    private getDateEndField(): BasesPropertyId | null {
        const v = this.config.get('dateEndField') as string | undefined;
        if (v) return v as BasesPropertyId;
        const def = this.plugin.settings.ganttDefaults.dateEndField;
        return def ? (def as BasesPropertyId) : null;
    }

    private getLabelField(): BasesPropertyId | null {
        const v = this.config.get('labelField') as string | undefined;
        return v ? (v as BasesPropertyId) : null;
    }

    private getDependenciesField(): BasesPropertyId | null {
        const v = this.config.get('dependenciesField') as string | undefined;
        if (v) return v as BasesPropertyId;
        const def = this.plugin.settings.ganttDefaults.dependenciesField;
        return def ? (def as BasesPropertyId) : null;
    }

    private getColorByField(): BasesPropertyId | null {
        const v = this.config.get('colorBy') as string | undefined;
        if (v) return v as BasesPropertyId;
        const def = this.plugin.settings.ganttDefaults.colorBy;
        return def ? (def as BasesPropertyId) : null;
    }

    private getProgressField(): BasesPropertyId | null {
        const v = this.config.get('progressField') as string | undefined;
        if (v) return v as BasesPropertyId;
        const def = this.plugin.settings.ganttDefaults.progressField;
        return def ? (def as BasesPropertyId) : null;
    }

    private getShowProgress(): boolean {
        const v = this.config.get('showProgress');
        if (typeof v === 'boolean') return v;
        if (typeof v === 'string') return v === 'true';
        return this.plugin.settings.ganttDefaults.showProgress;
    }

    private getShowExpectedProgress(): boolean {
        const v = this.config.get('showExpectedProgress');
        if (typeof v === 'boolean') return v;
        if (typeof v === 'string') return v === 'true';
        return false;
    }

    private getViewMode(): string {
        const v = this.config.get('viewMode') as string | undefined;
        return v || this.plugin.settings.ganttDefaults.viewMode || 'Day';
    }

    private getBarHeight(): number {
        const v = this.config.get('barHeight');
        if (typeof v === 'number') return v;
        if (typeof v === 'string') return parseInt(v, 10) || this.plugin.settings.ganttDefaults.barHeight;
        return this.plugin.settings.ganttDefaults.barHeight;
    }

    private getReadonlyDates(): boolean {
        const v = this.config.get('readonlyDates');
        if (typeof v === 'boolean') return v;
        if (typeof v === 'string') return v === 'true';
        return false;
    }

    private getReadonlyProgress(): boolean {
        const v = this.config.get('readonlyProgress');
        if (typeof v === 'boolean') return v;
        if (typeof v === 'string') return v === 'true';
        return false;
    }

    private getShowInternalPopup(): boolean {
        const v = this.config.get('showInternalPopup');
        if (typeof v === 'boolean') return v;
        if (typeof v === 'string') return v === 'true';
        return this.plugin.settings.ganttDefaults.showInternalPopup;
    }

    // ── Data rendering ─────────────────────────────────────────────────────────

    onDataUpdated(): void {
        if (!this.data?.data || !this.ganttEl) return;

        const config = this.buildTaskMapperConfig();
        const newSnapshot = JSON.stringify(config) + '|' + this.getDisplaySnapshot()
            + '|props:' + (this.data?.properties ?? []).join(',');

        // Build task list (respecting Bases grouped data)
        let tasks: GanttTask[];
        const groups = this.data.groupedData;
        const hasGroups = groups.length > 1 || (groups.length === 1 && groups[0].hasKey());

        // Build color slot map for colorBy field across ALL tasks
        const colorSlotMap = this.buildColorSlotMap(config);

        if (hasGroups) {
            tasks = [];
            for (let i = 0; i < groups.length; i++) {
                const group = groups[i];
                const groupTasks = mapEntriesToTasks(group.entries, config, colorSlotMap);
                if (groupTasks.length === 0) continue;
                const label = group.hasKey() ? String(group.key) : 'Ungrouped';
                const header = createGroupHeaderTask(label, i, groupTasks);
                if (header) tasks.push(header);
                tasks.push(...groupTasks);
            }
        } else {
            tasks = mapEntriesToTasks(this.data.data, config, colorSlotMap);
        }

        this.currentTasks = tasks;
        this.taskMap.clear();
        for (const t of tasks) this.taskMap.set(t.id, t);

        // Build entryMap from ALL entries regardless of grouping.
        // this.data.data may be empty when groups are active — iterate groups
        // to guarantee every entry is included.
        this.entryMap.clear();
        if (hasGroups) {
            for (const group of this.data.groupedData) {
                for (const e of group.entries) this.entryMap.set(e.file.path, e);
            }
        } else {
            for (const e of this.data.data) this.entryMap.set(e.file.path, e);
        }

        if (tasks.length === 0) {
            this.renderEmptyState(config);
            return;
        }

        // Clear empty state if showing
        const emptyEl = this.containerEl.querySelector('.gantt-empty-state');
        if (emptyEl) emptyEl.remove();

        // Inject color CSS before chart renders
        this.injectColorStyles(config, colorSlotMap);

        if (this.gantt && this.configSnapshot === newSnapshot) {
            // Only data changed → refresh in place
            this.gantt.refresh(tasks);
        } else {
            this.configSnapshot = newSnapshot;
            this.initGantt(tasks);
        }
    }

    /**
     * Build the TaskMapperConfig: fill from explicit config, then fall back
     * to auto-detection from available property types.
     */
    private buildTaskMapperConfig(): TaskMapperConfig {
        const auto = this.autoDetectProperties();

        const startProperty = this.getDateStartField() ?? auto.start;
        const endProperty = this.getDateEndField() ?? auto.end;
        const labelProperty = this.getLabelField() ?? null;
        const dependenciesProperty = this.getDependenciesField() ?? auto.dependencies;
        const colorByProperty = this.getColorByField() ?? auto.colorBy;
        const progressProperty = this.getProgressField() ?? auto.progress;
        const showProgress = this.getShowProgress() || (progressProperty != null && !this.config.get('progressField'));

        return {
            startProperty,
            endProperty,
            labelProperty,
            dependenciesProperty,
            colorByProperty,
            progressProperty,
            showProgress,
        };
    }

    /**
     * Auto-detect property mappings by inspecting the first entry's values
     * and matching property names to common naming conventions.
     */
    private autoDetectProperties(): {
        start: BasesPropertyId | null;
        end: BasesPropertyId | null;
        dependencies: BasesPropertyId | null;
        progress: BasesPropertyId | null;
        colorBy: BasesPropertyId | null;
    } {
        const allEntries = this.data?.data ?? [];
        if (allEntries.length === 0) {
            return { start: null, end: null, dependencies: null, progress: null, colorBy: null };
        }

        const firstEntry = allEntries[0];
        const dateProps: BasesPropertyId[] = [];
        const numberProps: BasesPropertyId[] = [];
        const stringProps: BasesPropertyId[] = [];

        // this.data.properties is the correct Bases API accessor for column IDs.
        // BasesEntry does not have a .properties getter.
        const propIds: BasesPropertyId[] = this.data?.properties ?? [];
        for (const propId of propIds) {
            const val = firstEntry.getValue(propId);
            if (val == null || val instanceof NullValue) continue;
            if (val instanceof DateValue) {
                dateProps.push(propId);
            } else if (val instanceof NumberValue) {
                numberProps.push(propId);
            } else {
                stringProps.push(propId);
            }
        }

        const normalize = (id: BasesPropertyId): string => {
            const dot = id.indexOf('.');
            return (dot >= 0 ? id.slice(dot + 1) : id).toLowerCase().replace(/[-_\s]/g, '');
        };

        const findByKeywords = (
            props: BasesPropertyId[],
            keywords: string[],
        ): BasesPropertyId | null => {
            for (const propId of props) {
                const name = normalize(propId);
                if (keywords.some(k => name.includes(k))) return propId;
            }
            return null;
        };

        const startKeywords = ['start', 'begin', 'from', 'created'];
        const endKeywords = ['end', 'due', 'finish', 'deadline', 'until'];

        let start = findByKeywords(dateProps, startKeywords);
        let end = findByKeywords(dateProps, endKeywords);
        if (!start && dateProps.length > 0) start = dateProps[0];
        if (!end && dateProps.length > 1) end = dateProps.find(p => p !== start) ?? null;

        const depKeywords = ['depend', 'block', 'after', 'prerequisite', 'requires'];
        const dependencies = findByKeywords(stringProps, depKeywords);

        const progressKeywords = ['progress', 'percent', 'completion', 'complete'];
        const progress = findByKeywords(numberProps, progressKeywords);

        const colorKeywords = ['status', 'priority', 'type', 'category', 'phase', 'stage'];
        const colorBy = findByKeywords(stringProps, colorKeywords);

        return { start, end, dependencies, progress, colorBy };
    }

    private getDisplaySnapshot(): string {
        return JSON.stringify({
            viewMode: this.config.get('viewMode'),
            barHeight: this.config.get('barHeight'),
            showProgress: this.config.get('showProgress'),
            showExpectedProgress: this.config.get('showExpectedProgress'),
            readonlyDates: this.config.get('readonlyDates'),
            readonlyProgress: this.config.get('readonlyProgress'),
            showInternalPopup: this.config.get('showInternalPopup'),
        });
    }

    // ── Color system ───────────────────────────────────────────────────────────

    /**
     * Build a map of colorBy property value → slot index (0..COLOR_SLOT_COUNT-1).
     * Up to COLOR_SLOT_COUNT unique values get a dedicated color slot;
     * additional values wrap around via modulo.
     */
    private buildColorSlotMap(config: TaskMapperConfig): Map<string, number> {
        const map = new Map<string, number>();
        if (!config.colorByProperty) return map;

        for (const entry of (this.data?.data ?? [])) {
            const val = entry.getValue(config.colorByProperty);
            const raw = extractRawValue(val);
            if (raw != null && !map.has(raw)) {
                map.set(raw, map.size % COLOR_SLOT_COUNT);
            }
        }
        return map;
    }

    /**
     * Inject a dynamic <style> block that assigns CSS colors for each slot.
     * Colors are resolved via the 3-tier priority system.
     */
    private injectColorStyles(config: TaskMapperConfig, colorSlotMap: Map<string, number>): void {
        if (!this.styleEl) return;

        if (!config.colorByProperty || colorSlotMap.size === 0) {
            this.styleEl.textContent = '';
            return;
        }

        // Build a reverse map: slot index → resolved hex/rgba color
        const slotColor = new Map<number, string>();
        for (const [value, idx] of colorSlotMap) {
            if (slotColor.has(idx)) continue; // first value owns the slot
            const fieldId = config.colorByProperty;
            slotColor.set(idx, this.resolveBarColor(fieldId, value));
        }

        const lines: string[] = [];
        for (const [idx, color] of slotColor) {
            lines.push(
                `.bases-gantt-view .gantt-color-${idx} .bar { fill: ${color} !important; }`,
                `.bases-gantt-view .gantt-color-${idx} .bar-progress { fill: ${this.darkenColor(color)} !important; }`,
                `.bases-gantt-view .gantt-color-${idx} .bar-label { fill: var(--text-normal) !important; }`,
            );
        }
        this.styleEl.textContent = lines.join('\n');
    }

    /**
     * Resolve a bar fill color for a (field, value) pair using the 3-tier priority:
     * 1. Pretty Properties plugin (via `window.PrettyPropertiesApi`)
     * 2. Plugin `valueStyles` settings
     * 3. Deterministic Solarized hash via `stringToColor`
     */
    private resolveBarColor(fieldId: BasesPropertyId, value: string): string {
        const propName = fieldId.split('.').pop() || fieldId;

        // Tier 1: Pretty Properties
        const ppColor = this.getPrettyPropertiesColor(propName, value);
        if (ppColor) return ppColor;

        // Tier 2: Plugin valueStyles
        const configured = this.plugin.settings.valueStyles[fieldId]?.[value]?.color;
        if (configured) return configured;

        // Tier 3: deterministic hash
        return stringToColor(value);
    }

    /**
     * Query the Pretty Properties public API for a full-opacity background color.
     * Returns null if PP is not installed, value is uncolored, or resolution fails.
     */
    private getPrettyPropertiesColor(propName: string, propValue: string): string | null {
        const ppApi = (window as WindowWithPP).PrettyPropertiesApi;
        if (!ppApi) return null;

        try {
            const colorSetting = ppApi.getPropertyBackgroundColorSetting(propName, propValue);
            if (!colorSetting || colorSetting === 'default' || colorSetting === 'none') return null;

            const namedColors = ['red', 'orange', 'yellow', 'green', 'cyan', 'blue', 'purple', 'pink'];

            if (typeof colorSetting === 'string' && namedColors.includes(colorSetting)) {
                const rgbStr = getComputedStyle(document.body)
                    .getPropertyValue(`--color-${colorSetting}-rgb`)
                    .trim();
                if (rgbStr) {
                    const parts = rgbStr.split(/[\s,]+/).map((n: string) => parseInt(n.trim(), 10));
                    if (parts.length >= 3 && parts.every((n: number) => !isNaN(n))) {
                        return `rgb(${parts[0]}, ${parts[1]}, ${parts[2]})`;
                    }
                }
                return null;
            }

            if (typeof colorSetting === 'object' && 'h' in colorSetting) {
                const { h, s, l } = colorSetting as PPColorSetting;
                return `hsl(${h}, ${s}%, ${l}%)`;
            }
        } catch {
            // PP API error — fall through
        }

        return null;
    }

    /** Slightly darken a color for the progress bar fill. */
    private darkenColor(color: string): string {
        // For CSS colors we can't easily darken in pure TS without parsing;
        // Use filter approach via CSS class instead — return the same color at 70% brightness.
        return color;
    }

    // ── Gantt initialization ───────────────────────────────────────────────────

    private initGantt(tasks: GanttTask[]): void {
        this.destroyGantt();
        this.ganttEl.empty();

        const VIEW_MODE_NORMALISE: Record<string, string> = {
            'Quarter day': 'Quarter Day',
            'Half day': 'Half Day',
        };
        const rawViewMode = this.getViewMode();
        const viewMode = VIEW_MODE_NORMALISE[rawViewMode] ?? rawViewMode;
        const barHeight = this.getBarHeight();
        const showProgress = this.getShowProgress();
        const showExpectedProgress = this.getShowExpectedProgress();
        const readonlyDates = this.getReadonlyDates();
        const readonlyProgress = this.getReadonlyProgress();
        const showInternalPopup = this.getShowInternalPopup();

        // Scroll to earliest task on first render
        const earliest = this.getEarliestTaskDate(tasks);

        const options: GanttOptions = {
            view_mode: viewMode,
            bar_height: barHeight,
            padding: 10,   // tighter rows (Frappe default is 18) for better screen use
            show_expected_progress: showExpectedProgress,
            readonly_dates: readonlyDates,
            readonly_progress: readonlyProgress || !showProgress,
            popup_on: 'click',
            move_dependencies: true,
            // Disable Frappe's built-in infinite-padding behaviour: it registers a
            // non-passive 'mousewheel' listener that triggers browser scroll violations.
            // We re-implement the same extension logic ourselves with { passive: true }.
            infinite_padding: false,
            scroll_to: earliest ? new Date(earliest + 'T00:00:00') : null,

            popup: showInternalPopup
                ? (ctx: PopupContext) => this.renderPopup(ctx, showProgress)
                : false,

            on_click: (task: FrappeTask) => {
                if (this.justDragged) { this.justDragged = false; return; }
                const ganttTask = this.findTask(task.id);
                if (!ganttTask || ganttTask.id.startsWith(GROUP_HEADER_PREFIX)) return;
                // When the internal popup is disabled, clicking the bar opens the note.
                // When the popup is enabled it shows on click (Frappe handles this).
                if (!showInternalPopup) {
                    openFileInNewTab(this.app, ganttTask.filePath);
                }
            },

            on_date_change: (task: FrappeTask, start: Date, end: Date) => {
                this.justDragged = true;
                if (task.id.startsWith(GROUP_HEADER_PREFIX)) return;
                const ganttTask = this.findTask(task.id);
                if (!ganttTask) return;
                const config = this.buildTaskMapperConfig();
                const updates: Record<string, string> = {};
                if (config.startProperty) {
                    updates[this.extractPropName(config.startProperty)] = formatDateForFrontmatter(start);
                }
                if (config.endProperty) {
                    updates[this.extractPropName(config.endProperty)] = formatDateForFrontmatter(end);
                }
                void this.writeFrontmatter(ganttTask.filePath, updates);
            },

            on_progress_change: (task: FrappeTask, progress: number) => {
                if (!showProgress) return;
                const ganttTask = this.findTask(task.id);
                if (!ganttTask) return;
                const config = this.buildTaskMapperConfig();
                if (config.progressProperty) {
                    void this.writeFrontmatter(ganttTask.filePath, {
                        [this.extractPropName(config.progressProperty)]: Math.round(progress),
                    });
                }
            },
        };

        // Capture global mouseup handlers Frappe Gantt registers on document during
        // construction (for cleanup on destroy). Passive scroll events are handled by
        // the module-level installPassivePatch() active for the full view lifetime.
        const captured: EventListener[] = [];
        const origProtoAdd = EventTarget.prototype.addEventListener;
        EventTarget.prototype.addEventListener = function (
            type: string,
            listener: EventListenerOrEventListenerObject,
            opts?: boolean | AddEventListenerOptions,
        ): void {
            if (this === document && type === 'mouseup') {
                captured.push(listener as EventListener);
            }
            return origProtoAdd.call(this, type, listener, opts);
        };

        try {
            this.gantt = new Gantt(this.ganttEl, tasks, options);
        } catch (err) {
            console.error('[Wise View] Gantt init failed:', err);
            this.ganttEl.empty();
            this.renderEmptyState(this.buildTaskMapperConfig());
            return;
        } finally {
            EventTarget.prototype.addEventListener = origProtoAdd;
        }

        this.capturedGlobalHandlers = captured;

        // Repopulate taskMap — destroyGantt() clears it, but we need it for
        // popup/click handlers that run after initGantt returns.
        this.taskMap.clear();
        for (const t of tasks) this.taskMap.set(t.id, t);

        // Apply milestone wrapper class (can't combine with color class due to Frappe's classList.add)
        for (const task of tasks) {
            if (task.isMilestone) {
                const wrapper = this.ganttEl.querySelector(`.bar-wrapper[data-id="${task.id}"]`);
                if (wrapper) wrapper.classList.add('gantt-milestone');
            }
        }

        // Register hover-based Page Preview delegation (Obsidian handles the Ctrl-key requirement).
        this.registerBarHoverPreview();

        // Guard the popup against viewport/container overflow clipping.
        this.registerPopupGuard();

        // Replace Frappe's non-passive mousewheel listener with our passive wheel handler.
        this.registerInfinitePadding();
    }

    private destroyGantt(): void {
        if (this.gantt) {
            this.gantt.clear();
            this.gantt.$container?.remove();
            this.gantt = null;
        }
        for (const handler of this.capturedGlobalHandlers) {
            document.removeEventListener('mouseup', handler);
        }
        this.capturedGlobalHandlers = [];
        this.currentTasks = [];
        this.taskMap.clear();
        // NOTE: entryMap is managed exclusively by onDataUpdated → do NOT clear here.
        // Clearing it here would wipe the entry lookup before any popup fires.
        if (this._barHoverHandler) {
            this.ganttEl?.removeEventListener('mouseover', this._barHoverHandler);
            this._barHoverHandler = null;
        }
        if (this._containerMouseDownHandler && this._ganttContainer) {
            this._ganttContainer.removeEventListener('mousedown', this._containerMouseDownHandler);
        }
        this._containerMouseDownHandler = null;
        this._ganttContainer = null;
        // _infinitePaddingHandler was attached to gantt.$container which is removed
        // from the DOM above; the reference is cleared here for GC.
        this._infinitePaddingHandler = null;
        this._popupContainerObs?.disconnect();
        this._popupContainerObs = null;
        this._popupStyleObs?.disconnect();
        this._popupStyleObs = null;
        if (this._popupClampRafId != null) {
            cancelAnimationFrame(this._popupClampRafId);
            this._popupClampRafId = null;
        }
    }

    // ── Infinite-padding wheel handler ────────────────────────────────────────

    /**
     * Frappe Gantt's built-in infinite-padding feature registers a non-passive
     * `mousewheel` listener on the scroll container (causing browser violations).
     * We disable that feature (`infinite_padding: false`) and re-implement the
     * same behaviour here using a `{ passive: true }` `wheel` listener.
     *
     * The logic mirrors Frappe's `bind_bar_events` infinite-padding block:
     * - scrolling past the left half  → extend `gantt_start` backward
     * - scrolling past the right half → extend `gantt_end` forward
     */
    private registerInfinitePadding(): void {
        const gantt = this.gantt;
        if (!gantt) return;
        const container = gantt.$container;
        if (!container) return;

        let busy = false;

        const handler = (): void => {
            if (!this.gantt || busy) return;

            // Access Frappe internals via any-cast (all are plain object properties).
            // eslint-disable-next-line @typescript-eslint/no-explicit-any
            const g = this.gantt as any;
            const extendBy: number = g.config?.extend_by_units ?? 10;
            const unit: string = g.config?.unit ?? 'day';
            const colW: number = g.config?.column_width ?? 45;
            const half = container.scrollWidth / 2;

            if (container.scrollLeft <= half) {
                const prev = container.scrollLeft;
                busy = true;
                g.gantt_start = this._shiftDate(g.gantt_start, -extendBy, unit);
                g.setup_date_values();
                g.render();
                container.scrollLeft = prev + colW * extendBy;
                setTimeout(() => { busy = false; }, 300);
            } else if (
                container.scrollWidth - (container.scrollLeft + container.clientWidth) <= half
            ) {
                const prev = container.scrollLeft;
                busy = true;
                g.gantt_end = this._shiftDate(g.gantt_end, extendBy, unit);
                g.setup_date_values();
                g.render();
                container.scrollLeft = prev;
                setTimeout(() => { busy = false; }, 300);
            }
        };

        this._infinitePaddingHandler = handler as EventListener;
        container.addEventListener('wheel', this._infinitePaddingHandler, { passive: true });
    }

    /**
     * Shift a Date by `amount` units using Frappe's unit names
     * ("hour", "day", "month", "year") or the single-char shorthand used
     * internally ("h", "d", "m", "y").
     */
    private _shiftDate(date: Date, amount: number, unit: string): Date {
        const d = new Date(date);
        switch (unit) {
            case 'hour': case 'h': d.setHours(d.getHours() + amount); break;
            case 'day': case 'd': d.setDate(d.getDate() + amount); break;
            case 'week': case 'w': d.setDate(d.getDate() + amount * 7); break;
            case 'month': case 'm': d.setMonth(d.getMonth() + amount); break;
            case 'year': case 'y': d.setFullYear(d.getFullYear() + amount); break;
            default: d.setDate(d.getDate() + amount); break;
        }
        return d;
    }

    // ── Popup viewport guard ───────────────────────────────────────────────────

    /**
     * Frappe Gantt positions `.popup-wrapper` absolutely inside `.gantt-container`
     * (overflow:auto). When a bar is near the bottom of the visible scroll area the
     * popup gets clipped — the simple `top - shift` fix breaks when the container
     * has scrolled because container-relative coords ≠ viewport coords.
     *
     * Fix: upgrade the popup to `position:fixed` (escapes every overflow ancestor)
     * by converting Frappe's container-relative top/left to viewport coordinates,
     * then clamping and applying as fixed.
     *
     * Re-entry guard: we disconnect the style observer before writing our own
     * style changes and reconnect immediately after, so our writes never
     * retrigger the clamping loop.
     */
    private registerPopupGuard(): void {
        this._popupContainerObs?.disconnect();
        this._popupStyleObs?.disconnect();
        if (this._popupClampRafId != null) {
            cancelAnimationFrame(this._popupClampRafId);
            this._popupClampRafId = null;
        }

        const container = this.ganttEl.querySelector<HTMLElement>('.gantt-container');
        if (!container) return;

        // Store container ref so destroyGantt can clean up the mousedown listener.
        this._ganttContainer = container;

        // Track cursor position on mousedown so the popup can be placed near the click.
        // Capturing it here avoids reading any layout properties inside the popup guard,
        // which eliminates the "forced reflow" DevTools violation on every click.
        this._containerMouseDownHandler = (e: MouseEvent) => {
            this._lastMouseClientX = e.clientX;
            this._lastMouseClientY = e.clientY;
        };
        container.addEventListener('mousedown', this._containerMouseDownHandler);

        // Let Frappe Gantt manage hiding the popup via `.hide` class,
        // but if we ever need to forcefully hide it, we can just add the class.
        container.addEventListener('click', (e: MouseEvent) => {
            const onBar = (e.target as Element)?.closest('.bar-wrapper');
            if (!onBar) {
                const popup = container.querySelector<HTMLElement>('.popup-wrapper');
                if (popup) popup.classList.add('hide');
            }
        });

        /**
         * Place the popup in `position:fixed` near the last click position.
         *
         * Previous approach read getBoundingClientRect + offsetWidth/Height inside a
         * requestAnimationFrame, which forced a synchronous layout and produced the
         * "Forced reflow while executing JavaScript took 70ms" DevTools violation.
         *
         * New approach: use the mouse coordinates captured on mousedown (pure numbers,
         * no layout reads) + window.innerWidth/Height (cheap, no reflow) to place and
         * clamp the popup entirely without touching the DOM for measurements.
         */
        const scheduleClamp = (popup: HTMLElement): void => {
            if (this._popupClampRafId != null) {
                cancelAnimationFrame(this._popupClampRafId);
                this._popupClampRafId = null;
            }

            this._popupClampRafId = requestAnimationFrame(() => {
                this._popupClampRafId = null;
                if (!popup.isConnected || popup.classList.contains('hide') || popup.style.display === 'none') return;

                // Use CSS-declared bounds (min-width:260px, max-width:340px from styles.css).
                // Fixed estimates avoid querying offsetWidth/offsetHeight (forced reflow).
                const popupW = 320;
                const popupH = 200;
                const offset = 14; // gap between cursor tip and popup corner
                const margin = 8;

                // Clamp to the Obsidian workspace content area (excludes left/right
                // sidebars) rather than the full window, so the popup never appears
                // underneath an open sidebar panel.
                const workspaceEl = document.querySelector<HTMLElement>(
                    '.workspace-split.mod-root',
                ) ?? document.querySelector<HTMLElement>('.workspace');
                const wBounds = workspaceEl?.getBoundingClientRect();
                const vLeft0 = wBounds?.left ?? 0;
                const vTop0 = wBounds?.top ?? 0;
                const vw = wBounds ? wBounds.left + wBounds.width : window.innerWidth;
                const vh = wBounds ? wBounds.top + wBounds.height : window.innerHeight;

                // Start below-right of the cursor
                let vLeft = this._lastMouseClientX + offset;
                let vTop = this._lastMouseClientY + offset;

                // Flip left if popup would overflow the right edge
                if (vLeft + popupW > vw - margin) {
                    vLeft = this._lastMouseClientX - popupW - offset;
                }
                // Flip above if popup would overflow the bottom edge
                if (vTop + popupH > vh - margin) {
                    vTop = this._lastMouseClientY - popupH - offset;
                }
                // Hard clamp within the workspace content area
                vLeft = Math.max(vLeft0 + margin, Math.min(vLeft, vw - popupW - margin));
                vTop = Math.max(vTop0 + margin, Math.min(vTop, vh - popupH - margin));

                // Disconnect so our own writes don't re-trigger clamping
                this._popupStyleObs?.disconnect();

                popup.style.position = 'fixed';
                popup.style.top = `${vTop}px`;
                popup.style.left = `${vLeft}px`;

                // Reconnect to catch Frappe repositioning (e.g. clicking another bar)
                if (popup.isConnected && this._popupStyleObs) {
                    this._popupStyleObs.observe(popup, {
                        attributes: true, attributeFilter: ['style'],
                    });
                }
            });
        };

        const attachStyleObs = (popup: HTMLElement): void => {
            this._popupStyleObs = new MutationObserver(() => {
                if (!popup.isConnected) return;
                // Frappe writes new top/left whenever it repositions the popup
                // (e.g. different bar clicked). Re-clamp near the current cursor.
                scheduleClamp(popup);
            });
            this._popupStyleObs.observe(popup, { attributes: true, attributeFilter: ['style'] });
        };

        // Watch for the popup element being inserted (Frappe creates it lazily)
        this._popupContainerObs = new MutationObserver(() => {
            const popup = container.querySelector<HTMLElement>('.popup-wrapper');
            if (popup && !this._popupStyleObs) {
                attachStyleObs(popup);
            } else if (!popup && this._popupStyleObs) {
                this._popupStyleObs.disconnect();
                this._popupStyleObs = null;
            }
        });
        this._popupContainerObs.observe(container, { childList: true });

        // In case the popup already exists (Gantt re-initialised without page reload)
        const existing = container.querySelector<HTMLElement>('.popup-wrapper');
        if (existing && !this._popupStyleObs) attachStyleObs(existing);
    }

    // ── Context menus ──────────────────────────────────────────────────────────

    private registerContextMenu(): void {
        this.ganttEl.addEventListener('contextmenu', (evt: MouseEvent) => {
            const wrapper = (evt.target as Element)?.closest('.bar-wrapper');
            if (!wrapper) return;
            const taskId = wrapper.getAttribute('data-id');
            if (!taskId) return;
            const task = this.findTask(taskId);
            if (task) this.showTaskContextMenu(evt, task);
        });
    }

    private showTaskContextMenu(evt: MouseEvent, task: GanttTask): void {
        if (task.id.startsWith(GROUP_HEADER_PREFIX)) return;

        const menu = new Menu();

        const fileExists = !!this.app.vault.getFileByPath(task.filePath);
        if (fileExists) {
            menu.addItem(item => {
                item.setTitle('Open note')
                    .setIcon('file-text')
                    .onClick(() => openFileInNewTab(this.app, task.filePath));
            });

            menu.addItem(item => {
                item.setTitle('Open in new tab')
                    .setIcon('file-plus')
                    .onClick(() => {
                        this.app.workspace.openLinkText(task.filePath, '', 'tab');
                    });
            });

            menu.addSeparator();
        }

        const showProgress = this.getShowProgress();
        if (showProgress) {
            const config = this.buildTaskMapperConfig();
            if (config.progressProperty) {
                for (const pct of [0, 25, 50, 75, 100]) {
                    menu.addItem(item => {
                        item.setTitle(`Set progress: ${pct}%`)
                            .setIcon('percent')
                            .setChecked(Math.round(task.progress ?? 0) === pct)
                            .onClick(() => {
                                const propName = this.extractPropName(config.progressProperty!);
                                void this.writeFrontmatter(task.filePath, { [propName]: pct });
                                this.gantt?.update_task(task.id, { progress: pct });
                            });
                    });
                }
                menu.addSeparator();
            }
        }

        menu.addItem(item => {
            item.setTitle('Scroll to today')
                .setIcon('calendar')
                .onClick(() => this.gantt?.scroll_current());
        });

        menu.showAtMouseEvent(evt);
    }

    // ── Rich hover popup ───────────────────────────────────────────────────────

    /**
     * Render the Frappe Gantt internal popup with a Kanban-card-inspired layout.
     *
     * Sections (in order):
     *  1. Date range + duration
     *  2. Countdown to end date
     *  3. Progress bar (if enabled)
     *  4. After / dependencies (names resolved from taskMap)
     *  5. Separator + extra base properties as labeled rows
     */
    private renderPopup(ctx: PopupContext, showProgress: boolean): void {
        const ganttTask = this.findTask(ctx.task.id);

        // Group headers — label only, no detail rows
        if (!ganttTask || ganttTask.id.startsWith(GROUP_HEADER_PREFIX)) {
            ctx.set_title(`<strong>${this.escapeHtml(ctx.task.name)}</strong>`);
            return;
        }

        ctx.set_title(this.escapeHtml(ctx.task.name));
        ctx.set_subtitle(''); // All info lives in the details section

        const parts: string[] = [];

        // ── Date range + duration ──────────────────────────────────────────────
        const start = ctx.task._start;
        const end = ctx.task._end;
        if (start && end) {
            const days = Math.max(1, Math.ceil((end.getTime() - start.getTime()) / 86_400_000));
            const dateRange = `${this.formatDisplayDate(start)} \u2192 ${this.formatDisplayDate(end)}`;
            parts.push(this.buildPopupRow(
                'date',
                `${this.escapeHtml(dateRange)} <span class="gantt-popup-meta">&middot; ${days} day${days !== 1 ? 's' : ''}</span>`,
            ));

            // ── Countdown to end date ──────────────────────────────────────────
            const now = new Date();
            now.setHours(0, 0, 0, 0);
            const daysLeft = Math.ceil((end.getTime() - now.getTime()) / 86_400_000);
            let countdownHtml: string;
            if (daysLeft > 0) {
                countdownHtml = `<span class="gantt-popup-countdown gantt-popup-countdown--ok">${daysLeft} day${daysLeft !== 1 ? 's' : ''} remaining</span>`;
            } else if (daysLeft === 0) {
                countdownHtml = `<span class="gantt-popup-countdown gantt-popup-countdown--warn">Due today</span>`;
            } else {
                const overdue = Math.abs(daysLeft);
                countdownHtml = `<span class="gantt-popup-countdown gantt-popup-countdown--overdue">${overdue} day${overdue !== 1 ? 's' : ''} overdue</span>`;
            }
            parts.push(this.buildPopupRow('left', countdownHtml));
        }

        // ── Progress row ──────────────────────────────────────────────────────
        if (showProgress && ctx.task.progress != null) {
            const pct = Math.round(ctx.task.progress);
            const progressHtml =
                `<div class="gantt-popup-progress-wrap">` +
                `<div class="gantt-popup-progress"><div class="gantt-popup-progress-bar" style="width:${pct}%"></div></div>` +
                `<span class="gantt-popup-meta">${pct}%</span>` +
                `</div>`;
            parts.push(this.buildPopupRow('progress', progressHtml));
        }

        // ── Dependencies (After) — resolved to human-readable names ───────────
        // NOTE: Frappe Gantt converts `dependencies` from a comma-string to an
        // array internally during prepare_tasks(). Guard against both types.
        const rawDeps = ctx.task.dependencies;
        if (rawDeps && (typeof rawDeps === 'string' ? rawDeps.trim() : (rawDeps as unknown as unknown[]).length)) {
            const depIds: string[] = Array.isArray(rawDeps)
                ? (rawDeps as unknown as string[]).map(s => String(s).trim()).filter(Boolean)
                : String(rawDeps).split(',').map(s => s.trim()).filter(Boolean);
            if (depIds.length > 0) {
                const depNames = depIds
                    .map(id => this.taskMap.get(id)?.name ?? id)
                    .map(n => this.escapeHtml(n))
                    .join(', ');
                parts.push(this.buildPopupRow('after', depNames));
            }
        }

        // ── Extra properties from base configuration ───────────────────────────
        const config = this.buildTaskMapperConfig();
        const entry = this.entryMap.get(ganttTask.filePath);
        if (entry) {
            const extraProps = this.getPopupExtraProperties(config);
            if (extraProps.length > 0) {
                parts.push('<div class="gantt-popup-separator"></div>');
                for (const propId of extraProps) {
                    const val = entry.getValue(propId);
                    if (!val || val instanceof NullValue) continue;
                    const rawVal = extractRawValue(val);
                    if (rawVal == null || rawVal.trim() === '') continue;
                    const propLabel = propId.split('.').pop() ?? propId;
                    const color = this.resolveBarColor(propId, rawVal);
                    const valueHtml =
                        `<span class="gantt-popup-badge"` +
                        ` style="background:${this.escapeHtml(color)}20;` +
                        `color:${this.escapeHtml(color)};` +
                        `border-color:${this.escapeHtml(color)}40">` +
                        `${this.escapeHtml(rawVal)}</span>`;
                    parts.push(this.buildPopupRow(propLabel, valueHtml));
                }
            }
        }

        ctx.set_details(parts.join(''));
    }

    /**
     * Build a single popup property row (Kanban card prop-row style).
     * @param label   Left-column label text (title-cased by CSS)
     * @param valueHtml  HTML string for the right-column value
     */
    private buildPopupRow(label: string, valueHtml: string): string {
        return (
            `<div class="gantt-popup-row">` +
            `<span class="gantt-popup-row-label">${this.escapeHtml(label)}</span>` +
            `<span class="gantt-popup-row-value">${valueHtml}</span>` +
            `</div>`
        );
    }

    /**
     * Return the property IDs from the base configuration to render as extra
     * rows in the internal popup (all properties except the reserved mapped fields
     * and Bases internal metadata properties).
     */
    private getPopupExtraProperties(config: TaskMapperConfig): BasesPropertyId[] {
        const reserved = new Set<BasesPropertyId | null>([
            config.startProperty,
            config.endProperty,
            config.labelProperty,
            config.dependenciesProperty,
            config.progressProperty,
            config.colorByProperty,
        ]);
        const internalPrefixes = [
            'note.name', 'note.file', 'note.ctime', 'note.mtime',
            'note.tags', 'note.aliases',
        ];
        return (this.data?.properties ?? []).filter(
            p => !reserved.has(p) && !internalPrefixes.some(ip => p === ip),
        );
    }

    /**
     * Register event delegation on ganttEl so hovering a bar while holding
     * Ctrl (Windows/Linux) or Meta (macOS) triggers Obsidian's Page Preview.
     *
     * We enforce the modifier check here rather than delegating to Obsidian's
     * "Default action to open links" setting so that Gantt bars always require
     * an explicit Ctrl+hover regardless of that global preference.
     */
    private registerBarHoverPreview(): void {
        if (this._barHoverHandler) {
            this.ganttEl.removeEventListener('mouseover', this._barHoverHandler);
            this._barHoverHandler = null;
        }
        let lastTriggeredId: string | null = null;
        this._barHoverHandler = (evt: Event) => {
            const mouseEvt = evt as MouseEvent;
            const target = mouseEvt.target as Element | null;
            if (!target) return;
            const wrapper = target.closest<Element>('.bar-wrapper[data-id]');
            // Reset when leaving all bars
            if (!wrapper) { lastTriggeredId = null; return; }
            const taskId = wrapper.getAttribute('data-id');
            if (!taskId) return;
            // Deduplicate: only fire once per bar-enter
            if (taskId === lastTriggeredId) return;
            lastTriggeredId = taskId;
            const task = this.findTask(taskId);
            if (!task || task.id.startsWith(GROUP_HEADER_PREFIX)) return;

            // Obsidian's Page Preview plugin handles the actual modifier key check
            // based on the user's settings. We just need to trigger the event.
            this.app.workspace.trigger('hover-link', {
                event: mouseEvt,
                source: BASES_GANTT_VIEW_ID,
                hoverParent: this.plugin,
                targetEl: wrapper as HTMLElement,
                linktext: task.filePath,
                sourcePath: '/',
            });
        };
        this.ganttEl.addEventListener('mouseover', this._barHoverHandler);
    }

    private formatDisplayDate(date: Date): string {
        const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
        return `${months[date.getMonth()]} ${date.getDate()}, ${date.getFullYear()}`;
    }

    private escapeHtml(str: unknown): string {
        // Coerce to string first — ctx.task fields may arrive as non-strings
        // (e.g. undefined, number) depending on the Frappe Gantt version.
        return String(str ?? '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
    }

    // ── Utility helpers ────────────────────────────────────────────────────────

    private findTask(id: string): GanttTask | undefined {
        return this.taskMap.get(id);
    }

    private extractPropName(propertyId: BasesPropertyId): string {
        const dot = propertyId.indexOf('.');
        return dot >= 0 ? propertyId.slice(dot + 1) : propertyId;
    }

    private getEarliestTaskDate(tasks: GanttTask[]): string | null {
        let earliest: string | null = null;
        for (const t of tasks) {
            if (!t.id.startsWith(GROUP_HEADER_PREFIX)) {
                if (!earliest || t.start < earliest) earliest = t.start;
            }
        }
        return earliest;
    }

    private async writeFrontmatter(
        filePath: string,
        updates: Record<string, string | number>,
    ): Promise<void> {
        const file = this.app.vault.getFileByPath(filePath);
        if (!file) return;
        await this.app.fileManager.processFrontMatter(file, fm => {
            for (const [key, value] of Object.entries(updates)) {
                fm[key] = value;
            }
        });
    }

    private renderEmptyState(config: TaskMapperConfig): void {
        // Clear old gantt if present
        this.destroyGantt();
        this.ganttEl.empty();

        // Remove existing empty state to avoid duplicates
        this.containerEl.querySelector('.gantt-empty-state')?.remove();

        const emptyEl = this.containerEl.createDiv({ cls: 'gantt-empty-state' });
        if (!config.startProperty) {
            emptyEl.createEl('p', {
                text: 'No start date property configured.',
                cls: 'gantt-empty-message',
            });
            emptyEl.createEl('p', {
                text: 'Open the view settings (⚙) and select a start date property.',
                cls: 'gantt-empty-hint',
            });
        } else {
            emptyEl.createEl('p', {
                text: 'No items with a valid start date found.',
                cls: 'gantt-empty-message',
            });
        }
    }
}

// ── View registration ────────────────────────────────────────────────────────

export function createGanttViewRegistration(plugin: PlannerPlugin): BasesViewRegistration {
    return {
        name: 'Gantt',
        icon: 'gantt-chart-square',
        factory: (controller: QueryController, containerEl: HTMLElement) =>
            new BasesGanttView(controller, containerEl, plugin),
        options: () => getGanttViewOptions(),
    };
}

/**
 * View option definitions for the Bases native config sidebar.
 * These appear when the user clicks the ⚙ gear icon on the view.
 *
 * NOTE: Must return a flat array — the Bases API does not support
 * `type: 'group'` wrappers and will crash with a `getOrder` null error
 * if grouped items are used. Keep options as a flat list.
 */
export function getGanttViewOptions(): BasesAllOptions[] {
    return [
        {
            type: 'property',
            key: 'dateStartField',
            displayName: 'Start date',
            placeholder: 'Select property…',
        },
        {
            type: 'property',
            key: 'dateEndField',
            displayName: 'End date',
            placeholder: 'Select property…',
        },
        {
            type: 'property',
            key: 'labelField',
            displayName: 'Label',
            placeholder: 'File name (default)',
        },
        {
            type: 'property',
            key: 'dependenciesField',
            displayName: 'Dependencies',
            placeholder: 'Select property…',
        },
        {
            type: 'property',
            key: 'colorBy',
            displayName: 'Color by',
            placeholder: 'Select property…',
        },
        {
            type: 'property',
            key: 'progressField',
            displayName: 'Progress',
            placeholder: 'Select property…',
        },
        {
            type: 'dropdown',
            key: 'viewMode',
            displayName: 'View mode',
            default: 'Day',
            options: {
                'Quarter day': 'Quarter day',
                'Half day': 'Half day',
                'Day': 'Day',
                'Week': 'Week',
                'Month': 'Month',
                'Year': 'Year',
            },
        },
        {
            type: 'slider',
            key: 'barHeight',
            displayName: 'Bar height',
            default: 30,
            min: 16,
            max: 60,
            step: 2,
        },
        {
            type: 'toggle',
            key: 'showProgress',
            displayName: 'Show progress',
            default: false,
        },
        {
            type: 'toggle',
            key: 'showExpectedProgress',
            displayName: 'Show expected progress',
            default: false,
        },
        {
            type: 'toggle',
            key: 'showInternalPopup',
            displayName: 'Show info popup on click',
            default: true,
        },
        {
            type: 'toggle',
            key: 'readonlyDates',
            displayName: 'Lock dates (no drag)',
            default: false,
        },
        {
            type: 'toggle',
            key: 'readonlyProgress',
            displayName: 'Lock progress (no drag)',
            default: false,
        },
    ];
}
