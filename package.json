		"@typescript-eslint/parser": "^8.53.0",
		"@typescript-eslint/utils": "^8.53.0",
		"@vitejs/plugin-vue": "^6.0.3",
		"builtin-modules": "^5.0.0",
		"dotenv": "^17.3.1",
		"esbuild": "^0.27.3",
